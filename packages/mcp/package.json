{
  "name": "opencode-lens-mcp",
  "version": "0.1.4",
  "description": "MCP server for discovering and controlling live opencode-lens TUI plugin instances.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "opencode-lens-mcp": "dist/opencode-lens-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "mcp",
    "model-context-protocol",
    "automation",
    "agent"
  ],
  "homepage": "https://github.com/wuxiaoqiang12/opencode-lens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuxiaoqiang12/opencode-lens.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/wuxiaoqiang12/opencode-lens/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && mv dist/index.js dist/opencode-lens-mcp.js",
    "build:binaries": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/opencode-lens-mcp-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/opencode-lens-mcp-linux-arm64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/opencode-lens-mcp-darwin-arm64",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@opencode-lens/shared": "workspace:*"
  }
}
