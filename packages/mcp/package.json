{
  "name": "opencode-lens-mcp",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "opencode-lens-mcp": "dist/opencode-lens-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun && mv dist/index.js dist/opencode-lens-mcp.js",
    "build:binaries": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-arm64",
    "build:linux-x64": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/opencode-lens-mcp-linux-x64",
    "build:linux-arm64": "bun build --compile --target=bun-linux-arm64 src/index.ts --outfile dist/opencode-lens-mcp-linux-arm64",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/opencode-lens-mcp-darwin-arm64",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opencode-lens/shared": "workspace:*"
  }
}
