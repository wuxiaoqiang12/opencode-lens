{
  "name": "opencode-lens",
  "version": "0.1.2",
  "description": "Observe and control your running opencode TUI sessions — an opencode plugin that exposes a local control API over a Unix socket.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./tui": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "tui",
    "agent"
  ],
  "homepage": "https://github.com/wuxiaoqiang12/opencode-lens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuxiaoqiang12/opencode-lens.git",
    "directory": "packages/plugin"
  },
  "bugs": {
    "url": "https://github.com/wuxiaoqiang12/opencode-lens/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.17",
    "@opencode-lens/shared": "workspace:*"
  }
}
